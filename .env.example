# K3s-Sentinel Environment Configuration
# Copy this file to .env and customize

# ============================================
# LLM Provider Configuration
# ============================================

# LLM Provider: openai, anthropic, gemini, azure_openai, ollama, local
LLM_PROVIDER=openai

# API Key for the LLM provider (REQUIRED)
LLM_API_KEY=

# Model to use
LLM_MODEL=gpt-4

# Optional parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# For Azure OpenAI:
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01

# For Ollama:
# OLLAMA_BASE_URL=http://localhost:11434

# For Custom (OpenAI-compatible APIs):
# CUSTOM_API_BASE_URL=https://api.example.com/v1

# System prompt for LLM
LLM_SYSTEM_PROMPT="You are a Kubernetes expert helping with root cause analysis. Analyze cluster issues and identify root causes with evidence and suggested fixes."

# ============================================
# Alert Configuration
# ============================================

# Enable/disable alerting
ALERTS_ENABLED=true
ALERT_MIN_SEVERITY=warning
ALERT_COOLDOWN_SECONDS=300

# Custom Webhook (generic)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook.com/alerts
WEBHOOK_HEADERS={"Authorization": "Bearer token"}

# Slack
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#alerts

# Microsoft Teams
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Email/SMTP
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-password
EMAIL_FROM=alerts@example.com
EMAIL_TO=admin@example.com,oncall@example.com

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Grafana
GRAFANA_ENABLED=false
GRAFANA_URL=https://grafana.example.com
GRAFANA_API_KEY=your-grafana-api-key

# ============================================
# Agent Settings
# ============================================

# Agent name
AGENT_NAME=k3s-sentinel

# K3s connection
KUBECONFIG_PATH=~/.kube/config
K3S_CONTEXT=default

# Polling intervals (seconds)
POLL_INTERVAL=10
LOG_LINES_TO_FETCH=100
CORRELATION_TIME_WINDOW=300

# Resource constraints
CPU_LIMIT=500m
MEMORY_LIMIT=512Mi

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/var/log/k3s-sentinel.log

# Vector database (for RAG)
VECTOR_DB_PATH=./data/vector_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# Dashboard Configuration
# ============================================

# Dashboard backend URL (default: http://localhost:8000)
BACKEND_API_URL=http://localhost:8000

# Dashboard server port
DASHBOARD_PORT=3000
